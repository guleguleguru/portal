<Window x:Class="DesktopPortal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="320"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#07080A"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Icon="/Assets/DesktopPortal.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PortalShellBrush" Color="#07080A" />
        <SolidColorBrush x:Key="PortalPanelBrush" Color="#0D0F12" />
        <SolidColorBrush x:Key="PortalPanelElevatedBrush" Color="#12151A" />
        <SolidColorBrush x:Key="PortalCardBrush" Color="#171B22" />
        <SolidColorBrush x:Key="PortalHairlineBrush" Color="#252A33" />
        <SolidColorBrush x:Key="PortalInkBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PortalMutedBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="PortalAccentBrush" Color="#57C1FF" />

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PortalCardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource PortalPanelElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="Foreground" Value="#051016" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PortalShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PortalShellBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <StackPanel>
                <TextBlock Text="设置"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PortalInkBrush}" />
                <TextBlock Text="本地启动和配置文件位置"
                           FontSize="12"
                           Foreground="{StaticResource PortalMutedBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource PortalPanelBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                Margin="22">
            <StackPanel>
                <Border Background="{StaticResource PortalPanelElevatedBrush}"
                        BorderBrush="{StaticResource PortalHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,18">
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="开机自动启动"
                              FontWeight="SemiBold" />
                </Border>

                <TextBlock Text="配置文件路径"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource PortalMutedBrush}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="ConfigPathTextBox" IsReadOnly="True" />
                <TextBlock Text="配置保存在本地 AppData 目录，不会同步到云端。"
                           Foreground="{StaticResource PortalMutedBrush}"
                           FontSize="12"
                           Margin="2,8,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PortalPanelBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <Button Content="保存"
                        Style="{StaticResource PrimaryDialogButtonStyle}"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button Content="取消"
                        Style="{StaticResource DialogButtonStyle}"
                        IsCancel="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
