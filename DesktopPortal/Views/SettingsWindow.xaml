<Window x:Class="DesktopPortal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="320"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF1F5"
        FontFamily="Microsoft YaHei UI"
        Icon="/Assets/DesktopPortal.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="LineBrush" Color="#D8DEE7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#146C94" />
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#11202A"
                Padding="22,18">
            <StackPanel>
                <TextBlock Text="设置"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="本地启动和配置文件位置"
                           FontSize="12"
                           Foreground="#A9BAC7"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                Margin="22">
            <StackPanel>
                <Border Background="#F8FBFC"
                        BorderBrush="#B7D8E6"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,18">
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="开机自动启动"
                              FontWeight="SemiBold" />
                </Border>

                <TextBlock Text="配置文件路径"
                           FontWeight="SemiBold"
                           Foreground="#344054"
                           Margin="0,0,0,6" />
                <TextBox x:Name="ConfigPathTextBox" IsReadOnly="True" />
                <TextBlock Text="配置保存在本地 AppData 目录，不会同步到云端。"
                           Foreground="#667085"
                           FontSize="12"
                           Margin="2,8,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <Button Content="保存"
                        Style="{StaticResource PrimaryDialogButtonStyle}"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button Content="取消"
                        Style="{StaticResource DialogButtonStyle}"
                        IsCancel="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
