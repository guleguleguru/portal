<Window x:Class="DesktopPortal.Views.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="规则"
        Height="650"
        Width="760"
        MinHeight="610"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="#07080A"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Icon="/Assets/DesktopPortal.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PortalShellBrush" Color="#07080A" />
        <SolidColorBrush x:Key="PortalPanelBrush" Color="#0D0F12" />
        <SolidColorBrush x:Key="PortalPanelElevatedBrush" Color="#12151A" />
        <SolidColorBrush x:Key="PortalCardBrush" Color="#171B22" />
        <SolidColorBrush x:Key="PortalHairlineBrush" Color="#252A33" />
        <SolidColorBrush x:Key="PortalInkBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PortalMutedBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="PortalFaintBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="PortalAccentBrush" Color="#57C1FF" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PortalMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PortalCardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PortalAccentBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PortalCardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource PortalPanelElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="Foreground" Value="#051016" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PortalShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PortalShellBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <StackPanel>
                <TextBlock Text="规则编辑"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PortalInkBrush}" />
                <TextBlock Text="配置快捷键、目标路径和窗口匹配提示。目标路径支持直接拖放文件、文件夹或程序。"
                           FontSize="12"
                           Foreground="{StaticResource PortalMutedBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="230" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PortalPanelBrush}"
                        BorderBrush="{StaticResource PortalHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock Text="名称" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="NameTextBox" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="目标类型" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox x:Name="TargetTypeComboBox"
                                          SelectionChanged="TargetTypeComboBox_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="URL 打开方式" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox x:Name="OpenModeComboBox" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Margin="0,0,0,14">
                            <TextBlock Text="目标路径" Style="{StaticResource FieldLabelStyle}" />
                            <Border BorderBrush="{StaticResource PortalHairlineBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource PortalPanelElevatedBrush}"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TargetTextBox"
                                                 Grid.Column="0"
                                                 AllowDrop="True"
                                                 PreviewDragOver="TargetTextBox_PreviewDragOver"
                                                 Drop="TargetTextBox_Drop" />
                                        <Button x:Name="BrowseButton"
                                                Grid.Column="1"
                                                Content="浏览"
                                                Style="{StaticResource DialogButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="BrowseButton_Click" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="把文件、文件夹或 .exe 程序拖到这里，软件会自动识别目标类型。"
                                               Foreground="{StaticResource PortalMutedBrush}"
                                               FontSize="12"
                                               Margin="2,8,0,0"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,0,0,14">
                            <TextBlock Text="快捷键" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="HotkeyTextBox"
                                         Grid.Column="0"
                                         IsReadOnly="True" />
                                <Button x:Name="CaptureHotkeyButton"
                                        Grid.Column="1"
                                        Content="录入快捷键"
                                        Style="{StaticResource DialogButtonStyle}"
                                        Margin="8,0,0,0"
                                        Click="CaptureHotkeyButton_Click" />
                            </Grid>
                            <TextBlock x:Name="HotkeyHintText"
                                       Text="支持数字键、F1-F12、鼠标中键/侧键，或 Ctrl/Alt/Shift + 字母/数字组合。"
                                       Foreground="{StaticResource PortalMutedBrush}"
                                       FontSize="12"
                                       Margin="2,8,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="4" Margin="0,0,0,14">
                            <TextBlock Text="窗口标题提示" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="WindowTitleHintTextBox" />
                        </StackPanel>

                        <CheckBox x:Name="EnabledCheckBox"
                                  Grid.Row="5"
                                  Content="启用此规则"
                                  IsChecked="True"
                                  Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource PortalPanelBrush}"
                        BorderBrush="{StaticResource PortalHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="录入建议"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PortalInkBrush}" />
                        <TextBlock Text="数字键、F1-F12、鼠标中键和侧键会作为单键记录。软件运行期间，这些单键会被 Desktop Portal 独占。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource PortalMutedBrush}"
                                   Margin="0,10,0,0" />
                        <Separator Margin="0,16" Background="{StaticResource PortalHairlineBrush}" />
                        <TextBlock Text="URL 独立窗口"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PortalInkBrush}" />
                        <TextBlock Text="独立窗口会优先使用 Chrome，其次 Edge；找不到浏览器时自动回退默认浏览器。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource PortalMutedBrush}"
                                   Margin="0,8,0,0" />
                        <Separator Margin="0,16" Background="{StaticResource PortalHairlineBrush}" />
                        <TextBlock Text="标题提示"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PortalInkBrush}" />
                        <TextBlock Text="文件或网页窗口不容易精确匹配时，可以填写窗口标题中的关键词。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource PortalMutedBrush}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource PortalPanelBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel LastChildFill="False">
                <Button Content="保存"
                        Style="{StaticResource PrimaryDialogButtonStyle}"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button Content="取消"
                        Style="{StaticResource DialogButtonStyle}"
                        IsCancel="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
