<Window x:Class="DesktopPortal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面传送门 Desktop Portal"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="1020"
        Background="#07080A"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Icon="/Assets/DesktopPortal.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PortalShellBrush" Color="#07080A" />
        <SolidColorBrush x:Key="PortalPanelBrush" Color="#0D0F12" />
        <SolidColorBrush x:Key="PortalPanelElevatedBrush" Color="#12151A" />
        <SolidColorBrush x:Key="PortalCardBrush" Color="#171B22" />
        <SolidColorBrush x:Key="PortalHairlineBrush" Color="#252A33" />
        <SolidColorBrush x:Key="PortalInkBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="PortalMutedBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="PortalFaintBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="PortalAccentBrush" Color="#57C1FF" />
        <SolidColorBrush x:Key="PortalSuccessBrush" Color="#59D499" />
        <SolidColorBrush x:Key="PortalWarningBrush" Color="#FFC533" />
        <SolidColorBrush x:Key="PortalDangerBrush" Color="#FF6161" />
        <SolidColorBrush x:Key="PortalDangerSurfaceBrush" Color="#2A1417" />

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource PortalPanelElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalAccentBrush}" />
            <Setter Property="Foreground" Value="#051016" />
        </Style>

        <Style x:Key="DangerCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PortalDangerBrush}" />
            <Setter Property="BorderBrush" Value="#4A252B" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource PortalMutedBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="KeycapBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PortalCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="TypeBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#0E2330" />
            <Setter Property="BorderBrush" Value="#23506A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#10221B" />
            <Setter Property="BorderBrush" Value="#275D43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasIssue}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PortalDangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="#73323A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Enabled}" Value="False">
                    <Setter Property="Background" Value="#171A20" />
                    <Setter Property="BorderBrush" Value="#323743" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{StaticResource PortalPanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#101318" />
            <Setter Property="Foreground" Value="{StaticResource PortalMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource PortalHairlineBrush}" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PortalShellBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PortalShellBrush}"
                BorderBrush="{StaticResource PortalHairlineBrush}"
                BorderThickness="0,0,1,0"
                Padding="22">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Border Width="42"
                            Height="42"
                            Background="{StaticResource PortalPanelElevatedBrush}"
                            BorderBrush="{StaticResource PortalHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalAlignment="Left">
                        <Image Source="/Assets/DesktopPortal.ico" Width="24" Height="24" />
                    </Border>

                    <TextBlock Text="Desktop Portal"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PortalInkBrush}"
                               Margin="0,16,0,0" />
                    <TextBlock Text="桌面传送门"
                               FontSize="13"
                               Foreground="{StaticResource PortalMutedBrush}"
                               Margin="0,5,0,0" />

                    <Border Background="{StaticResource PortalPanelBrush}"
                            BorderBrush="{StaticResource PortalHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="运行状态"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PortalMutedBrush}" />
                            <TextBlock x:Name="PausedStateText"
                                       Text="状态：正常"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PortalInkBrush}"
                                       Margin="0,10,0,0" />
                            <TextBlock Text="关闭窗口后仍会留在系统托盘。"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{StaticResource PortalFaintBrush}"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{StaticResource PortalPanelBrush}"
                                BorderBrush="{StaticResource PortalHairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="已启用" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="RegisteredCountText" Text="0" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Background="{StaticResource PortalPanelBrush}"
                                BorderBrush="{StaticResource PortalHairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="冲突" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ConflictCountText"
                                           Text="0"
                                           Foreground="{StaticResource PortalDangerBrush}"
                                           Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="{StaticResource PortalPanelBrush}"
                            BorderBrush="{StaticResource PortalHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="规则总数"
                                       FontSize="12"
                                       Foreground="{StaticResource PortalMutedBrush}" />
                            <TextBlock x:Name="RulesCountText"
                                       Text="0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PortalInkBrush}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="配置文件"
                               Foreground="{StaticResource PortalMutedBrush}"
                               FontSize="12"
                               Margin="0,0,0,6" />
                    <Border Background="{StaticResource PortalPanelBrush}"
                            BorderBrush="{StaticResource PortalHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <TextBlock x:Name="ConfigPathText"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{StaticResource PortalFaintBrush}" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="规则命令中心"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PortalInkBrush}" />
                    <TextBlock Text="为网页、文件、文件夹和程序配置全局快捷键；冲突和健康检查结果会显示在状态列。"
                               FontSize="13"
                               Foreground="{StaticResource PortalMutedBrush}"
                               Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource PortalPanelBrush}"
                        BorderBrush="{StaticResource PortalHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="本地 JSON · 无账号 · 无云同步"
                               Foreground="{StaticResource PortalAccentBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{StaticResource PortalPanelBrush}"
                    BorderBrush="{StaticResource PortalHairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,14">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button x:Name="AddButton" Content="新增规则" Style="{StaticResource PrimaryCommandButtonStyle}" Click="AddButton_Click" />
                        <Button x:Name="EditButton" Content="编辑" Style="{StaticResource CommandButtonStyle}" Click="EditButton_Click" />
                        <Button x:Name="DeleteButton" Content="删除" Style="{StaticResource DangerCommandButtonStyle}" Click="DeleteButton_Click" />
                        <Button x:Name="TestButton" Content="测试执行" Style="{StaticResource CommandButtonStyle}" Click="TestButton_Click" />
                        <Button x:Name="HealthCheckButton" Content="健康检查" Style="{StaticResource CommandButtonStyle}" Click="HealthCheckButton_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="PauseAllButton" Content="暂停全部" Style="{StaticResource CommandButtonStyle}" Click="PauseAllButton_Click" />
                        <Button x:Name="SettingsButton" Content="设置" Style="{StaticResource CommandButtonStyle}" Click="SettingsButton_Click" Margin="0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PortalPanelBrush}"
                    BorderBrush="{StaticResource PortalHairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <DataGrid x:Name="RulesGrid"
                          ItemsSource="{Binding Rules}"
                          CurrentCellChanged="RulesGrid_CurrentCellChanged"
                          PreviewMouseRightButtonDown="RulesGrid_PreviewMouseRightButtonDown"
                          PreviewMouseRightButtonUp="RulesGrid_PreviewMouseRightButtonUp">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{StaticResource PortalPanelBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PortalInkBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PortalPanelElevatedBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#10202B" />
                                </Trigger>
                                <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource PortalDangerBrush}" />
                                    <Setter Property="Background" Value="#151012" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource PortalFaintBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="启用"
                                                Width="64"
                                                Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="名称"
                                            Width="150"
                                            Binding="{Binding Name}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            IsReadOnly="True" />
                        <DataGridTemplateColumn Header="快捷键" Width="132">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource KeycapBadgeStyle}">
                                        <TextBlock Text="{Binding Hotkey}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PortalInkBrush}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="类型" Width="96">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TypeBadgeStyle}">
                                        <TextBlock Text="{Binding TargetTypeText}"
                                                   Foreground="{StaticResource PortalAccentBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="打开方式"
                                            Width="108"
                                            Binding="{Binding OpenModeText}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="目标"
                                            Width="*"
                                            Binding="{Binding Target}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="标题提示"
                                            Width="130"
                                            Binding="{Binding WindowTitleHint}"
                                            ElementStyle="{StaticResource GridTextStyle}"
                                            IsReadOnly="True" />
                        <DataGridTemplateColumn Header="状态" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusPillStyle}">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PortalInkBrush}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
