<Window x:Class="DesktopPortal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面传送门 Desktop Portal"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#EEF1F5"
        FontFamily="Microsoft YaHei UI"
        Icon="/Assets/DesktopPortal.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#17202A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DEE7" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#146C94" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0F4F6D" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF0F4" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="Foreground" Value="#526071" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E7EBF0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="258" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#11202A"
                Padding="22">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Desktop Portal"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="桌面传送门"
                               FontSize="13"
                               Foreground="#A9BAC7"
                               Margin="0,5,0,0" />

                    <Border Background="#1A3140"
                            BorderBrush="#25495E"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="运行状态"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#D8E5ED" />
                            <TextBlock x:Name="PausedStateText"
                                       Text="状态：正常"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,10,0,0" />
                            <TextBlock Text="关闭窗口后仍会留在系统托盘。"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="#A9BAC7"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#F8FBFC"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="已启用" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="RegisteredCountText" Text="0" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Background="#FFF8F6"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="冲突" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ConflictCountText" Text="0" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#162A37"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="规则总数"
                                       FontSize="12"
                                       Foreground="#A9BAC7" />
                            <TextBlock x:Name="RulesCountText"
                                       Text="0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="配置文件"
                               Foreground="#A9BAC7"
                               FontSize="12"
                               Margin="0,0,0,6" />
                    <TextBlock x:Name="ConfigPathText"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#D8E5ED" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="规则控制台"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="为网页、文件、文件夹和程序配置全局快捷键；冲突会直接显示在状态列。"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#E6F2F7"
                        BorderBrush="#B7D8E6"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="本地 JSON 配置 · 无账号 · 无云同步"
                               Foreground="#0F4F6D"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,14">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button x:Name="AddButton" Content="新增规则" Style="{StaticResource PrimaryButtonStyle}" Click="AddButton_Click" />
                        <Button x:Name="EditButton" Content="编辑" Style="{StaticResource ToolbarButtonStyle}" Click="EditButton_Click" />
                        <Button x:Name="DeleteButton" Content="删除" Style="{StaticResource DangerButtonStyle}" Click="DeleteButton_Click" />
                        <Button x:Name="TestButton" Content="测试执行" Style="{StaticResource ToolbarButtonStyle}" Click="TestButton_Click" />
                        <Button x:Name="HealthCheckButton" Content="健康检查" Style="{StaticResource ToolbarButtonStyle}" Click="HealthCheckButton_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="PauseAllButton" Content="暂停全部" Style="{StaticResource ToolbarButtonStyle}" Click="PauseAllButton_Click" />
                        <Button x:Name="SettingsButton" Content="设置" Style="{StaticResource ToolbarButtonStyle}" Click="SettingsButton_Click" Margin="0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <DataGrid x:Name="RulesGrid"
                          ItemsSource="{Binding Rules}"
                          CurrentCellChanged="RulesGrid_CurrentCellChanged"
                          PreviewMouseRightButtonDown="RulesGrid_PreviewMouseRightButtonDown"
                          PreviewMouseRightButtonUp="RulesGrid_PreviewMouseRightButtonUp">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="#EDF0F4" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                    <Setter Property="Foreground" Value="#B42318" />
                                    <Setter Property="Background" Value="#FFF8F6" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                    <Setter Property="Foreground" Value="#8A94A3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="启用"
                                                Width="64"
                                                Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="名称" Width="150" Binding="{Binding Name}" IsReadOnly="True" />
                        <DataGridTextColumn Header="快捷键" Width="118" Binding="{Binding Hotkey}" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="类型" Width="92">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF6F9"
                                            BorderBrush="#C8E2EC"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="9,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TargetTypeText}"
                                                   Foreground="#0F4F6D"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="打开方式" Width="108" Binding="{Binding OpenModeText}" IsReadOnly="True" />
                        <DataGridTextColumn Header="目标" Width="*" Binding="{Binding Target}" IsReadOnly="True" />
                        <DataGridTextColumn Header="标题提示" Width="130" Binding="{Binding WindowTitleHint}" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="状态" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="9,3"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F8F4" />
                                                <Setter Property="BorderBrush" Value="#BFE3C7" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                                        <Setter Property="Background" Value="#FEE4E2" />
                                                        <Setter Property="BorderBrush" Value="#F97066" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                        <Setter Property="Background" Value="#F2F4F7" />
                                                        <Setter Property="BorderBrush" Value="#D0D5DD" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
